import re
from typing import Dict, List, Tuple


CRISIS_KEYWORDS = [
    "suicide",
    "suicidal",
    "kill myself",
    "end my life",
    "want to die",
    "self harm",
    "self-harm",
    "hurt myself",
    "can't go on",
    "cannot go on",
    "no reason to live",
    "better off dead",
    "i wish i was dead",
]

NEGATION_PHRASES = [
    "not suicidal",
    "not suicide",
    "not going to kill myself",
    "not going to hurt myself",
    "i am safe",
    "i'm safe",
    "i don't want to die",
    "i do not want to die",
    "not rope",
    "not pills",
    "not poison",
    "not a knife",
]

LOOPING_KEYWORDS = [
    "again and again",
    "looping",
    "spiralling",
    "spiraling",
    "can't stop thinking",
    "stuck in my head",
    "same thoughts",
    "repeating thoughts",
]

DISTRESS_KEYWORDS = [
    "hopeless",
    "worthless",
    "alone",
    "lonely",
    "panic",
    "terrified",
    "overwhelmed",
    "breaking down",
    "can't cope",
    "cannot cope",
    "exhausted",
    "need help",
]

PLANNING_KEYWORDS = [
    "goodbye",
    "farewell",
    "after i'm gone",
    "after i am gone",
    "final letter",
    "last message",
    "everyone will be better off",
]

METHOD_KEYWORDS = [
    "overdose",
    "rope",
    "hanging",
    "jump off",
    "jumping",
    "knife",
    "pills",
    "poison",
]

CATEGORY_WEIGHTS = {
    "crisis": 5,
    "method": 5,
    "planning": 3,
    "looping": 1,
    "distress": 1,
}


def normalize_text(user_text: str) -> str:
    if not user_text:
        return ""
    return user_text.lower().strip()


def phrase_to_regex(phrase: str) -> str:
    escaped = re.escape(phrase)
    escaped = escaped.replace(r"\ ", r"\s+")
    return r"(?<!\w)" + escaped + r"(?!\w)"


def find_matches(text: str, phrases: List[str]) -> List[str]:
    matches = []

    for phrase in phrases:
        pattern = phrase_to_regex(phrase)
        if re.search(pattern, text):
            matches.append(phrase)

    return matches


def remove_negated_method_matches(matches: Dict[str, List[str]], text: str) -> None:
    filtered_methods = []

    for method in matches["method"]:
        negation_pattern = phrase_to_regex("not " + method)
        if not re.search(negation_pattern, text):
            filtered_methods.append(method)

    matches["method"] = filtered_methods


def remove_negated_crisis_matches(matches: Dict[str, List[str]], text: str) -> None:
    negated_pairs = {
        "suicidal": "not suicidal",
        "suicide": "not suicide",
        "kill myself": "not going to kill myself",
        "hurt myself": "not going to hurt myself",
        "want to die": "i don't want to die",
    }

    filtered_crisis = []

    for phrase in matches["crisis"]:
        negation = negated_pairs.get(phrase)

        if negation:
            negation_pattern = phrase_to_regex(negation)
            if re.search(negation_pattern, text):
                continue

        filtered_crisis.append(phrase)

    matches["crisis"] = filtered_crisis


def analyse_risk(user_text: str) -> Dict[str, object]:
    text = normalize_text(user_text)

    matches = {
        "crisis": find_matches(text, CRISIS_KEYWORDS),
        "method": find_matches(text, METHOD_KEYWORDS),
        "planning": find_matches(text, PLANNING_KEYWORDS),
        "looping": find_matches(text, LOOPING_KEYWORDS),
        "distress": find_matches(text, DISTRESS_KEYWORDS),
        "negation": find_matches(text, NEGATION_PHRASES),
    }

    remove_negated_method_matches(matches, text)
    remove_negated_crisis_matches(matches, text)

    score = 0

    for category, weight in CATEGORY_WEIGHTS.items():
        if matches[category]:
            score += weight

    if matches["negation"] and not matches["method"] and not matches["planning"]:
        score = max(0, score - 4)

    if score >= 8:
        level = "critical"
    elif score >= 5:
        level = "crisis"
    elif score >= 2:
        level = "elevated"
    else:
        level = "normal"

    return {
        "level": level,
        "score": score,
        "matches": matches,
    }


def critical_response() -> str:
    return (
        "[CRITICAL] High-risk language detected. "
        "Please seek immediate support from emergency services, "
        "a crisis line, or a trusted person nearby."
    )


def crisis_response() -> str:
    return (
        "[CRISIS] Crisis language detected. "
        "Please reach out for immediate support and avoid being alone."
    )


def elevated_distress_response() -> str:
    return (
        "[ELEVATED] Signs of distress detected. "
        "Slow things down. Focus only on the next few safe minutes."
    )


def normal_response() -> str:
    return "[NORMAL] Normal response flow continues here."


def handle_user_message(user_text: str) -> Tuple[str, Dict[str, object]]:
    result = analyse_risk(user_text)
    level = result["level"]

    if level == "critical":
        response = critical_response()
    elif level == "crisis":
        response = crisis_response()
    elif level == "elevated":
        response = elevated_distress_response()
    else:
        response = normal_response()

    return response, result


def run_tests() -> None:
    test_messages = [
        "I can't go on",
        "I'm spiralling and hopeless",
        "I wrote a goodbye letter and bought pills",
        "I am not suicidal, just exhausted",
        "I don't want to die, I just need help",
        "I need help",
        "I am safe but exhausted",
        "This is a ropey argument, not rope",
        "Hello how are you",
    ]

    for message in test_messages:
        response, result = handle_user_message(message)

        print("USER:", message)
        print("BOT:", response)
        print("LEVEL:", result["level"])
        print("SCORE:", result["score"])
        print("MATCHES:", result["matches"])
        print("-" * 50)


if __name__ == "__main__":
    run_tests()
